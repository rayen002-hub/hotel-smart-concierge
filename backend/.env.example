# Configuration du serveur
PORT=5000
NODE_ENV=development

# Base de données PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/hotel_concierge

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=24h

# QR Code Secrets
CLIENT_QR_SECRET=your_client_qr_secret_here
WORKER_QR_SECRET=your_worker_qr_secret_here
CHECKIN_QR_SECRET=your_checkin_qr_secret_here

# Frontend URL (pour CORS et generation de QR)
FRONTEND_URL=http://localhost:3000

# Socket.IO CORS Origin (si different de FRONTEND_URL, optionnel)
SOCKET_CORS_ORIGIN=http://localhost:3000

# AI Service URL
AI_SERVICE_URL=http://localhost:8000

# Cle de chiffrement des champs sensibles (32 caracteres pour AES-256)
FIELD_ENCRYPTION_KEY=12345678901234567890123456789012

# Supabase Storage (pour l'upload d'images en production)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=
